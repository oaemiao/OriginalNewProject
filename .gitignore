bin
log
cache

# data - runtime-only subdirectories
data/rcp/
data/rct/
data/sounds/

# ====================================================================
# db/ — 项目 RAID 数据库目录
# ====================================================================
# db/ 目录本身不能完全忽略！其中的 .dbd 文件是项目数据库定义，
# 描述数据模型、报警配置、归档策略等，是 WinCC OA 打开项目的
# 必要条件。新机器 clone 后首次启动时，OA 会自动根据 .dbd 定义
# 创建初始的 .db / .key 文件。
#
# 以下规则按"跟踪 vs 忽略"分类：

# ---- 必须跟踪 ----
# .dbd 数据库定义文件 —— 定义项目结构，几乎不变，无忽略规则。

# ---- 必须忽略（运行时自动生成） ----
# .db 运行时数据库文件 —— 每次启动分配/增长，机器相关
db/**/*.db
# .key 运行时数据库索引文件 —— 同上
db/**/*.key

# VistaDB 运行时日志（每次运行生成，机器相关）
db/wincc_oa/vista.log
# TAF 事务归档文件（运行中持续写入，启停时重建）
db/wincc_oa/wccoaone.taf
db/wincc_oa/vista.taf

# 数据库状态标记文件（启动创建/关闭删除）
db/wincc_oa/dbase.status
db/wincc_oa/dbase.touch
db/wincc_oa/event.status

# VA_* 归档运行时目录（每次启动自动创建，数量取决于
# config/progs 中 WCCOAvalarch -num 的实例数）
db/wincc_oa/VA_*/

colorDB/.colorDB.lock

help
msg/

# scripts
*.ctc

# panels
panels/**/*.ba?
!panels/OAE*/

# 过滤备份和临时文件
*.bak
*.tmp
~*
*.exe
*.rar

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
build/
dist/
pip-wheel-metadata/
env/
venv/
.venv
.env
.env.*
.python-version
htmlcov/
